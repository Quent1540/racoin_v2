{
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "twig/twig": "3.*",
        "illuminate/database": "11.*",
        "monolog/monolog": "^3.0",
        "ext-mysqli": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^0.15"
    },
    "autoload": {
        "psr-4": {
            "App\\Controller\\": "controller/",
            "App\\Model\\": "model/",
            "App\\Db\\": "db/"
        }
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    }
}
